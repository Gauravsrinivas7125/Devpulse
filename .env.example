# ============================================================================
# DevPulse Environment Variables Template
# ============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have sensible defaults

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8000
DEBUG=False
# Environment: development | staging | production
ENVIRONMENT=production
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000

# ============================================================================
# Database [REQUIRED for production]
# ============================================================================
# SQLite (development - no setup needed):
#   DATABASE_URL=sqlite:///./devpulse.db
# PostgreSQL (production):
#   DATABASE_URL=postgresql://user:password@localhost:5432/devpulse
DATABASE_URL=sqlite:///./devpulse.db
# Set to "false" to use in-memory storage (no persistence)
USE_DATABASE=true
# Set to "true" to log SQL queries (development only)
SQL_ECHO=false

# ============================================================================
# Redis (optional - for caching and rate limiting)
# ============================================================================
REDIS_URL=redis://localhost:6379
# Set to "false" to disable Redis (falls back to in-memory cache)
USE_REDIS=false

# ============================================================================
# Authentication [REQUIRED]
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE-ME-generate-a-secure-random-secret-key-here
JWT_ALGORITHM=HS256
# Token expiration in seconds (default: 1 hour)
JWT_EXPIRATION=3600

# ============================================================================
# OpenAI (required for AI security analysis)
# ============================================================================
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# Stripe (required for billing)
# ============================================================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_your-stripe-key
# Get webhook secret at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price IDs for each plan tier
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# ============================================================================
# Email Service (optional - for notifications)
# ============================================================================
# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Sender name and email
EMAIL_FROM_NAME=DevPulse
EMAIL_FROM_ADDRESS=noreply@devpulse.io

# ============================================================================
# Slack Integration (optional - for alerts)
# ============================================================================
# Create a Slack app at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ============================================================================
# Supabase (optional - alternative database)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================================================
# Webhook Configuration (optional)
# ============================================================================
# Maximum retry attempts for failed webhook deliveries
WEBHOOK_MAX_RETRIES=3
# Timeout in seconds for webhook HTTP requests
WEBHOOK_TIMEOUT=10

# ============================================================================
# Logging
# ============================================================================
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Set to "true" to output JSON-formatted logs
LOG_JSON=false
